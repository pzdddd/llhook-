+fun getMapHtml(provider: MapProvider, apiKey: String, lat: Float, lng: Float): String {
+    return when (provider) {
+        MapProvider.AMAP -> """
+            <!DOCTYPE html>
+            <html>
+            <head>
+                <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
+                <script type="text/javascript">
+                    window._AMapSecurityConfig = { securityJsCode: '' } 
+                </script>
+                <script type="text/javascript" src="https://webapi.amap.com/maps?v=2.0&key=$apiKey"></script>
+                <style> body { margin: 0; padding: 0; } #map { width: 100vw; height: 100vh; } </style>
+            </head>
+            <body>
+                <div id="map"></div>
+                <script>
+                    var map = new AMap.Map('map', { center: [$lng, $lat], zoom: 15 });
+                    var marker = new AMap.Marker({ position: [$lng, $lat] });
+                    map.add(marker);
+                    map.on('click', function(e) {
+                        marker.setPosition(e.lnglat);
+                        Android.onLocationPicked(e.lnglat.getLat(), e.lnglat.getLng());
+                    });
+                </script>
+            </body>
+            </html>
+        """.trimIndent()
+        MapProvider.TENCENT -> """
+            <!DOCTYPE html>
+            <html>
+            <head>
+                <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
+                <script charset="utf-8" src="https://map.qq.com/api/gljs?v=1.exp&key=$apiKey"></script>
+                <style> body { margin: 0; padding: 0; } #map { width: 100vw; height: 100vh; } </style>
+            </head>
+            <body>
+                <div id="map"></div>
+                <script>
+                    var center = new TMap.LatLng($lat, $lng);
+                    var map = new TMap.Map(document.getElementById('map'), { center: center, zoom: 15 });
+                    var marker = new TMap.MultiMarker({
+                        map: map,
+                        geometries: [{ id: '1', styleId: 'marker', position: center }]
+                    });
+                    map.on('click', function(e) {
+                        marker.updateGeometries([{ id: '1', styleId: 'marker', position: e.latLng }]);
+                        Android.onLocationPicked(e.latLng.lat, e.latLng.lng);
+                    });
+                </script>
+            </body>
+            </html>
+        """.trimIndent()
+        MapProvider.BAIDU -> """
+            <!DOCTYPE html>
+            <html>
+            <head>
+                <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
+                <script type="text/javascript" src="https://api.map.baidu.com/api?v=3.0&ak=$apiKey"></script>
+                <style> body { margin: 0; padding: 0; } #map { width: 100vw; height: 100vh; } </style>
+            </head>
+            <body>
+                <div id="map"></div>
+                <script>
+                    var map = new BMap.Map("map");
+                    var point = new BMap.Point($lng, $lat);
+                    map.centerAndZoom(point, 15);
+                    var marker = new BMap.Marker(point);
+                    map.addOverlay(marker);
+                    map.addEventListener("click", function(e) {
+                        var pt = e.point;
+                        marker.setPosition(pt);
+                        Android.onLocationPicked(pt.lat, pt.lng);
+                    });
+                </script>
+            </body>
+            </html>
+        """.trimIndent()
+    }
+}
